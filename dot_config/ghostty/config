# Typography
font-family = "FiraCode Nerd Font"
font-size = 13

# Window Styles (Zen Aesthetics)
window-decoration = false
window-padding-x = 16
window-padding-y = 16
scrollback-limit = 100000

# Glassmorphism Effects
background-opacity = 0.82
background-blur = true

# Color Palette
theme = dark-pastel
